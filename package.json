{
	"name": "ticketing-billing-monorepo",
	"private": true,
	"packageManager": "yarn@4.12.0",
	"workspaces": [
		"apps/*",
		"infra/*"
	],
	"scripts": {
		"dev": "yarn workspace @ticketing-billing/web dev",
		"build": "yarn workspace @ticketing-billing/web build",
		"start": "yarn workspace @ticketing-billing/web start",
		"lint": "yarn workspace @ticketing-billing/web lint",
		"cdk:synth": "yarn workspace @ticketing-billing/cdk synth",
		"cdk:diff": "yarn workspace @ticketing-billing/cdk diff",
		"cdk:deploy": "yarn workspace @ticketing-billing/cdk deploy",
		"cdk:bootstrap": "yarn workspace @ticketing-billing/cdk bootstrap"
	}
}